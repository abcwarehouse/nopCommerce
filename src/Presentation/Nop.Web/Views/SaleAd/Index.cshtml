<h2>Sale Ads</h2>
<table class="table">
    <thead>
        <tr>
            <th>ProductId</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Display Order</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sale in Model)
        {
            <tr>
                <td>@sale.Product</td>
                <td>@sale.StartDate.ToShortDateString()</td>
                <td>@sale.EndDate.ToShortDateString()</td>
                <td>@sale.DisplayOrder</td>
            </tr>
        }
    </tbody>
</table>






<style>
.permanent-marker-regular, p, a {
  font-family: "Permanent Marker", cursive !important;
  font-weight: 400;
  font-style: normal;
}
.image-container {
    position: relative;
}
.mickey-top-banner img {
    width: 100%;
}
.mickey-sale-banners img {
    width: 100%;
}
.banner-half {
    width: 48%;
    float: left;
    position: relative;
}
.sale-ad-button {
    background: #f0c82c;
    text-align: center;
    font-weight: bold;
    padding: 5px 10px;
	border-left: solid #000;
    border-right: solid #000;
    border-bottom: solid #000;
}
.sale-ad-button a {
    text-decoration: none;
	color: #000;
	font-weight: 900;
    font-size: 16px;
    text-transform: uppercase;
}
.item-box .prices {
    height: auto;
}
.content-box {
    background: #fff;
    padding: 20px 20px;
}
.content-box .product-box-description {
    line-height: 1.25;
    font-weight: bold;
}
.content-box {
    background: #fff;
    padding: 15px 15px;
    border: solid 3px #000;
}
.content-box .add-info {
    line-height: 1.25;
	margin: 0px;
}
.product-grid {
    padding-top: 30px;
}
.mickey-right-banner.banner-half {
    margin-left: 2%;
}
.mickey-left-banner.banner-half {
    margin-right: 2%;
}
img.right-border-img {
    position: absolute;
    right: -9px;
    top: 0;
    height: 100%;
    width: auto;
}
img.bottom-boarder-img {
    position: absolute;
    bottom: 1px;
    left: 0;
    width: 100%;
}
img.bottom-boarder-productbox {
    position: absolute;
    bottom: -6px;
    left: 5px;
    width: 100%;
}
img.right-border-productbox {
    position: absolute;
    right: -6px;
    top: 0;
    height: 100%;
    width: auto;
}
.promo-page h2.product-title {
    padding: 0;
	height: auto;
}
.page.promo-page .item-number {
    margin: 0;
}
.promo-page .item-box .product-title span.man-no {
    font-weight: bold;
}
.item-box .product-title a {
	text-decoration: none;
}

</style>