    <!-- UUID library + Cookie/Session Management -->
    <script defer src="https://cdn.jsdelivr.net/npm/uuid@8.3.2/dist/umd/uuidv4.min.js"></script>
    <script>
        try {
            (function() {
                console.log('[SEARCHSPRING] Initializing cookie/session management');

                // Utility functions
                function getCookie(name) {
                    try {
                        var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                        return match ? match[2] : null;
                    } catch(e) {
                        console.error('[SEARCHSPRING] getCookie error:', e);
                        return null;
                    }
                }

                function setCookie(name, value, days) {
                    try {
                        var expires = "";
                        if (days) {
                            var date = new Date();
                            date.setTime(date.getTime() + (days*24*60*60*1000));
                            expires = "; expires=" + date.toUTCString();
                        }
                        document.cookie = name + "=" + value + expires + "; path=/; SameSite=Lax";
                    } catch(e) {
                        console.error('[SEARCHSPRING] setCookie error:', e);
                    }
                }

                function generateUUID() {
                    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                        var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
                        return v.toString(16);
                    });
                }

                function getOrCreateId(cookieName, days) {
                    let id = getCookie(cookieName);
                    if (!id) {
                        id = Math.random().toString(36).substring(2) + Date.now();
                        setCookie(cookieName, id, days || 365);
                    }
                    return id;
                }

                // Initialize ssShopperId
                var ssShopperId = getCookie("ssShopperId");
                if (!ssShopperId) {
                    ssShopperId = generateUUID();
                    setCookie("ssShopperId", ssShopperId, 365);
                }
                console.log('[SEARCHSPRING] ssShopperId initialized:', ssShopperId.substring(0,8) + '...');

                // Initialize ssSessionIdNamespace
                var sessionKey = "ssSessionIdNamespace";
                if (!sessionStorage.getItem(sessionKey)) {
                    var uuid = typeof uuidv4 === 'function' ? uuidv4() : generateUUID();
                    sessionStorage.setItem(sessionKey, uuid);
                    setCookie(sessionKey, uuid, 1);
                    console.log('[SEARCHSPRING] Session ID initialized');
                }

                // Set intellisuggest configuration (with defensive checks)
                try {
                    if (typeof window.intellisuggest === 'undefined' || window.intellisuggest === null) {
                        window.intellisuggest = [];
                        console.log('[SEARCHSPRING] Intellisuggest initialized as array');
                    }

                    // Only push if push is actually a function (it's an array)
                    if (typeof window.intellisuggest.push === 'function') {
                        window.intellisuggest.push(['setSiteId', '4lt84w']);
                        window.intellisuggest.push(["setShopperId", ssShopperId]);
                        console.log('[SEARCHSPRING] Intellisuggest configuration pushed');
                    } else {
                        console.log('[SEARCHSPRING] Intellisuggest.push is not a function, deferring config');
                        // Retry after 300ms if intellisuggest script is replacing our array
                        setTimeout(function() {
                            try {
                                if (typeof window.intellisuggest !== 'undefined' &&
                                    typeof window.intellisuggest.push === 'function') {
                                    window.intellisuggest.push(['setSiteId', '4lt84w']);
                                    window.intellisuggest.push(["setShopperId", ssShopperId]);
                                    console.log('[SEARCHSPRING] Intellisuggest configuration pushed (deferred)');
                                }
                            } catch(e) {
                                console.warn('[SEARCHSPRING] Deferred push error:', e.message);
                            }
                        }, 300);
                    }
                } catch(e) {
                    console.warn('[SEARCHSPRING] Intellisuggest config error:', e.message);
                    // Still try to configure after delay as fallback
                    setTimeout(function() {
                        try {
                            if (typeof window.intellisuggest !== 'undefined' &&
                                typeof window.intellisuggest.push === 'function') {
                                window.intellisuggest.push(['setSiteId', '4lt84w']);
                                window.intellisuggest.push(["setShopperId", ssShopperId]);
                            }
                        } catch(e2) {
                            console.warn('[SEARCHSPRING] Final fallback push failed:', e2.message);
                        }
                    }, 500);
                }

                // Make utilities globally available
                window.ssUtils = {
                    getCookie: getCookie,
                    setCookie: setCookie,
                    generateUUID: generateUUID,
                    getOrCreateId: getOrCreateId
                };

                console.log('[SEARCHSPRING] Initialization complete');
            })();
        } catch(e) {
            console.error('[SEARCHSPRING] Fatal initialization error:', e.message);
            console.error('[SEARCHSPRING] Stack:', e.stack);
        }
    </script>

    <!-- SearchSpring Suggest Integration (with error handling) -->
    <script>
        (function initSearchSpring() {
            try {
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', function initOnReady() {
                        try {
                            setupSearchInput();
                        } catch (e) {
                            console.error('[SEARCHSPRING] DOMContentLoaded setup error:', e);
                        }
                    });
                } else {
                    setupSearchInput();
                }

                function setupSearchInput() {
                    var searchBox = document.querySelector('#small-searchterms')
                        || document.querySelector('input[type="search"]')
                        || document.querySelector('input[name="q"]');

                    if (!searchBox) {
                        console.log('[SEARCHSPRING] No search input found');
                        // Don't return - just exit the function normally
                    } else {
                        console.log('[SEARCHSPRING] Search box found, initializing suggest');
                        setupDebounceListener(searchBox);
                    }
                }

                function debounce(func, wait) {
                    var timeout;
                    return function debounced() {
                        var args = Array.prototype.slice.call(arguments);
                        clearTimeout(timeout);
                        timeout = setTimeout(function() {
                            func.apply(this, args);
                        }, wait);
                    };
                }

                function setupDebounceListener(searchBox) {
                    try {
                        searchBox.addEventListener('input', debounce(function onInput() {
                            try {
                                var query = this.value.trim();
                                if (query.length < 2) {
                                    // Skip this query
                                } else if (typeof window.ssUtils === 'undefined') {
                                    console.log('[SEARCHSPRING] ssUtils not yet available');
                                } else {
                                    var userId = window.ssUtils.getCookie('ssShopperId');
                                    var sessionId = window.ssUtils.getCookie('ssSessionIdNamespace');

                                    var suggestUrl = '/searchspring/suggest?q=' + encodeURIComponent(query);
                                    if (userId) suggestUrl += '&userId=' + encodeURIComponent(userId);
                                    if (sessionId) suggestUrl += '&sessionId=' + encodeURIComponent(sessionId);

                                    fetch(suggestUrl)
                                        .then(function(response) { return response.json(); })
                                        .then(function(data) {
                                            console.log('[SEARCHSPRING] Suggest request successful');
                                        })
                                        .catch(function(e) {
                                            console.error('[SEARCHSPRING] Suggest fetch error:', e);
                                        });
                                }
                            } catch (e) {
                                console.error('[SEARCHSPRING] Input handler error:', e);
                            }
                        }, 300));
                    } catch (e) {
                        console.error('[SEARCHSPRING] Listener setup error:', e);
                    }
                }
            } catch (e) {
                console.error('[SEARCHSPRING] Fatal initialization error:', e);
            }
        })();
    </script>

    <!-- Global Error Handler (suppress third-party widget errors) -->
    <script>
        // Suppress MutationObserver errors from third-party widgets
        window.addEventListener('error', function(event) {
            if (event.message && event.message.includes('MutationObserver') && event.message.includes('not of type')) {
                console.warn('[ERROR HANDLER] Suppressed third-party MutationObserver error:', event.message);
                event.preventDefault(); // Suppress the error
                return true;
            }
        }, true); // Use capture phase to catch errors early

        // Also handle unhandled promise rejections for MutationObserver
        window.addEventListener('unhandledrejection', function(event) {
            if (event.reason && event.reason.message && event.reason.message.includes('MutationObserver')) {
                console.warn('[ERROR HANDLER] Suppressed unhandled rejection:', event.reason.message);
                event.preventDefault(); // Suppress the rejection
            }
        });

        // Wrap MutationObserver to catch errors at source
        var OriginalMutationObserver = window.MutationObserver;
        window.MutationObserver = function(callback) {
            var wrappedCallback = function(mutations) {
                try {
                    callback(mutations);
                } catch(e) {
                    console.warn('[ERROR HANDLER] Caught MutationObserver callback error:', e.message);
                    // Don't rethrow - let it fail silently
                }
            };
            this._observer = new OriginalMutationObserver(wrappedCallback);
        };
        window.MutationObserver.prototype.observe = function(target, options) {
            try {
                if (!target || !(target instanceof Node)) {
                    console.warn('[ERROR HANDLER] MutationObserver.observe called with invalid target:', target);
                    return; // Silently fail instead of throwing
                }
                this._observer.observe(target, options);
            } catch(e) {
                console.warn('[ERROR HANDLER] MutationObserver.observe error:', e.message);
            }
        };
        window.MutationObserver.prototype.disconnect = function() {
            try {
                this._observer.disconnect();
            } catch(e) {
                console.warn('[ERROR HANDLER] MutationObserver.disconnect error:', e.message);
            }
        };
        window.MutationObserver.prototype.takeRecords = function() {
            try {
                return this._observer.takeRecords();
            } catch(e) {
                console.warn('[ERROR HANDLER] MutationObserver.takeRecords error:', e.message);
                return [];
            }
        };
    </script>

    <!-- GA4 Diagnostic Logger -->
    <script>
        window.ga4Diagnostics = {
            consentDefaults: null,
            consentUpdates: [],
            pageViewFired: false,
            termlyEventFired: false,
            referrer: document.referrer || '(none)',
            startTime: new Date().toISOString(),
            userAgent: navigator.userAgent,

            log: function(msg) {
                console.log('[GA4 DIAGNOSTICS]', msg);
            },

            logEvent: function(eventType, data) {
                console.log('[GA4 DIAGNOSTICS] EVENT:', eventType, data);
                if (!this.events) this.events = [];
                this.events.push({ time: new Date().toISOString(), type: eventType, data: data });
            }
        };

        ga4Diagnostics.log('Session started at ' + ga4Diagnostics.startTime);
        ga4Diagnostics.log('Referrer: ' + ga4Diagnostics.referrer);
        ga4Diagnostics.log('User Agent: ' + ga4Diagnostics.userAgent);
    </script>

    <!-- Google Consent Mode v2 (must load BEFORE gtag.js and GTM) -->
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}

        console.log('[CONSENT MODE] Initializing Consent Mode v2 defaults (denying all)');
        console.log('[REFERRAL] Initial referrer:', document.referrer || '(direct)');

        ga4Diagnostics.log('Consent Mode defaults about to be set');
        ga4Diagnostics.consentDefaults = { time: new Date().toISOString(), state: 'denied' };

        gtag('consent', 'default', {
            'ad_storage': 'denied',
            'analytics_storage': 'granted',  // ← Analytics is essential, not advertising
            'ad_user_data': 'denied',
            'ad_personalization': 'denied',
            'wait_for_update': 2000  // ← Increased timeout from 500ms to 2s
        });
        console.log('[CONSENT MODE] Default: analytics=GRANTED (essential), ads=denied, wait=2s');
        console.log('[CONSENT MODE] Defaults set - waiting up to 2000ms (2s) for Termly update');

        // Listen for Termly consent changes using Termly's API (event: 'consent')
        var termlyInitialEventFired = false;
        var userOptedOutEventSent = false;

        // Check if opted_out event was already sent in this session
        try {
            userOptedOutEventSent = sessionStorage.getItem('ga4_user_opted_out_sent') === 'true';
        } catch (e) {
            // sessionStorage might be blocked in private/incognito mode
        }

        if (window.Termly && typeof window.Termly.on === 'function') {
            window.Termly.on('consent', function(consentStatus) {
                ga4Diagnostics.termlyEventFired = true;
                console.log('[CONSENT MODE] Termly consent event detected:', consentStatus);
                ga4Diagnostics.logEvent('consent', consentStatus);

                // Skip consent update if user hasn't made a choice yet (consentState === null)
                // If consentState is not null, user has actively made a choice (accept or decline)
                var isInitialLoad = consentStatus?.consentState === null;

                if (isInitialLoad) {
                    console.log('[CONSENT MODE] Initial Termly event (user has not interacted with banner yet) - keeping defaults, skipping consent update');
                    if (!termlyInitialEventFired) {
                        termlyInitialEventFired = true;
                    }
                    return; // Don't update consent or send opted_out event yet
                }

                // User has made a choice - update consent accordingly
                // Map Termly consent properties to GA4 consent mode properties
                // Termly stores consent values inside consentState object:
                // consentStatus.consentState = {analytics, advertising, performance, social_networking, unclassified, essential, ...}
                // GA4 uses: analytics_storage, ad_storage, ad_user_data, ad_personalization

                var consentConfig = {
                    'ad_storage': consentStatus?.consentState?.advertising ? 'granted' : 'denied',
                    'analytics_storage': consentStatus?.consentState?.analytics ? 'granted' : 'denied',
                    'ad_user_data': consentStatus?.consentState?.advertising ? 'granted' : 'denied',
                    'ad_personalization': consentStatus?.consentState?.advertising ? 'granted' : 'denied'
                };

                ga4Diagnostics.consentUpdates.push({ time: new Date().toISOString(), state: consentConfig });

                // IMPORTANT: Send opted_out event BEFORE denying consent, but ONLY ONCE per session
                // If we deny analytics consent first, GA4 might refuse to send the event
                if (consentConfig.analytics_storage === 'denied' && !userOptedOutEventSent) {
                    userOptedOutEventSent = true;
                    console.log('[CONSENT MODE] User actively declined analytics - sending opted_out event BEFORE consent update (first time this session)');
                    gtag('event', 'user_opted_out', {
                        'opted_out_category': 'analytics_storage',
                        'opt_out_source': 'termly_banner',
                        'timestamp': new Date().toISOString()
                    });
                    console.log('[CONSENT MODE] GA4 opted_out event sent (before consent denial)');

                    // Mark that we've sent this event in this session
                    try {
                        sessionStorage.setItem('ga4_user_opted_out_sent', 'true');
                    } catch (e) {
                        // sessionStorage might be blocked, but we still have the variable
                    }
                } else if (consentConfig.analytics_storage === 'denied' && userOptedOutEventSent) {
                    console.log('[CONSENT MODE] User is declined, but opted_out event already sent this session - skipping');
                }

                console.log('[CONSENT MODE] User made a choice - updating consent to:', consentConfig);
                console.log('[REFERRAL] Referral data now protected with consent state:', consentConfig.analytics_storage);
                ga4Diagnostics.log('Consent updated: analytics=' + consentConfig.analytics_storage + ', ad=' + consentConfig.ad_storage);
                gtag('consent', 'update', consentConfig);
            });
            console.log('[CONSENT MODE] Termly event listener attached via Termly.on("consent")');
        } else {
            console.log('[CONSENT MODE] Termly not available or does not have .on() method');
        }
    </script>

    <!-- Bot Detection for GA4 (marks direct referral sessions where user leaves in <500ms with zero interaction) -->
    <script>
        (function initBotDetection() {
            try {
                var pageLoadStart = performance.now();
                var botDetected = false;
                var hasUserInteraction = false;
                var isDirect = !document.referrer || document.referrer === '';

                console.log('[BOT DETECTION] Initialized - Direct traffic: ' + isDirect + ', tracking page exit timing + user interaction');

                // Only proceed with bot detection for direct traffic
                if (!isDirect) {
                    console.log('[BOT DETECTION] External referrer detected (' + document.referrer + ') - bot detection disabled to avoid false positives from email/social redirects');
                    return;
                }

                // Track any user interaction (mouse, keyboard, scroll, touch)
                var interactionEvents = ['mousemove', 'mousedown', 'click', 'keydown', 'scroll', 'touchstart', 'touchmove'];
                interactionEvents.forEach(function(event) {
                    document.addEventListener(event, function() {
                        hasUserInteraction = true;
                        console.log('[BOT DETECTION] User interaction detected: ' + event);
                    }, { once: true }); // Only listen once to mark interaction
                });

                function checkAndReportBot() {
                    if (botDetected) return; // Only report once

                    var elapsedMs = performance.now() - pageLoadStart;

                    // Only mark as bot if: page exit in <500ms AND zero user interaction (direct traffic only)
                    if (elapsedMs < 500 && !hasUserInteraction) {
                        botDetected = true;
                        console.log('[BOT DETECTION] Suspicious activity detected - DIRECT traffic exit at ' + elapsedMs.toFixed(0) + 'ms with ZERO interaction');

                        // Send GA4 event marking as suspicious traffic
                        if (typeof gtag === 'function') {
                            gtag('event', 'suspicious_traffic', {
                                'traffic_quality': 'bot_suspected',
                                'exit_timing_ms': Math.round(elapsedMs),
                                'page_url': window.location.pathname,
                                'user_interaction': 'none',
                                'traffic_source': 'direct'
                            });
                            console.log('[BOT DETECTION] GA4 event sent - traffic marked as suspicious');
                        }
                    }
                }

                // Listen for page unload/navigation
                window.addEventListener('beforeunload', checkAndReportBot, true);
                window.addEventListener('unload', checkAndReportBot, true);

                // Also check on visibility change (tab closed or switched)
                document.addEventListener('visibilitychange', function() {
                    if (document.hidden) {
                        checkAndReportBot();
                    }
                });

                console.log('[BOT DETECTION] Event listeners attached - will only flag DIRECT exits <500ms with ZERO user interaction');
            } catch(err) {
                console.error('[BOT DETECTION] Initialization error:', err.message);
            }
        })();
    </script>

