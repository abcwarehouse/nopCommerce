@model AbcWarehouse.Plugin.Widgets.GA4.Models.GA4Model

@{
  var debugModeText = Model.IsDebugMode ? ", { 'debug_mode':true }" : string.Empty;
}

<!-- Google tag (gtag.js) with Consent Mode v2 & AI Assistant Channel Grouping -->
<script src="https://www.googletagmanager.com/gtag/js?id=@Model.GoogleTag"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}

  console.log('[GA4 RACE CONDITION FIX] Starting initialization sequence');
  console.log('[GA4] Script load time:', new Date().toISOString());

  // Ensure consent mode defaults are set (if not already set by _Root.Head.cshtml)
  if (!window.consentModeInitialized) {
    console.log('[CONSENT MODE] Not yet initialized, setting defaults now');
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'analytics_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'wait_for_update': 500
    });
    window.consentModeInitialized = true;
  } else {
    console.log('[CONSENT MODE] Already initialized by _Root.Head.cshtml');
  }

  gtag('js', new Date());

  console.log('[GA4] Initializing with tag: @Model.GoogleTag');
  console.log('[GA4] Referrer:', document.referrer || '(direct)');
  console.log('[GA4] User Agent:', navigator.userAgent);

  // Enable event queueing to buffer events during consent race condition
  var ga4Config = {
    'allow_google_signals': false,
    'allow_ad_personalization_signals': false,
    'cookie_flags': 'SameSite=Lax;secure'
  };
  @if (!string.IsNullOrEmpty(debugModeText))
  {
    <text>
    ga4Config['debug_mode'] = true;
    </text>
  }
  gtag('config','@Model.GoogleTag', ga4Config);

  // Detect email traffic by checking user agent (most email clients send a specific UA)
  function detectEmailTraffic() {
    var userAgent = navigator.userAgent.toLowerCase();

    var emailClientIndicators = [
      'apple mail',
      'outlook',
      'thunderbird',
      'gmail',
      'yahoo mail',
      'aol',
      'mail app',
      'ios mail',
      'android mail',
      'mobile safari.*mail',
      'mailspring',
      'the bat',
      'evolution',
      'mutt'
    ];

    console.log('[EMAIL DETECTION] Checking user agent for email client indicators');
    for (var i = 0; i < emailClientIndicators.length; i++) {
      if (userAgent.includes(emailClientIndicators[i])) {
        console.log('[EMAIL DETECTION] ✅ Email client detected:', emailClientIndicators[i]);
        return true;
      }
    }

    // Check for common email app contexts
    if (window.location.href.includes('utm_medium=email') ||
        window.location.href.includes('utm_source=email')) {
      console.log('[EMAIL DETECTION] ✅ Email UTM parameter detected in URL');
      return true;
    }

    console.log('[EMAIL DETECTION] No email client detected (standard browser)');
    return false;
  }

  // Custom channel grouping for AI assistant traffic (ChatGPT, Gemini, Claude, etc.)
  function classifyTrafficSource() {
    var referrer = document.referrer.toLowerCase();
    var userAgent = navigator.userAgent.toLowerCase();

    var aiAssistantSources = [
      'openai.com',
      'chatgpt.com',
      'chat.openai.com',
      'gemini.google.com',
      'bard.google.com',
      'claude.ai',
      'copilot.microsoft.com',
      'perplexity.ai'
    ];

    console.log('[REFERRAL CLASSIFICATION] Analyzing traffic source');
    console.log('[REFERRAL CLASSIFICATION] Referrer:', referrer || '(none)');

    // Check for email traffic first (highest priority since referrer is stripped)
    if (!referrer && detectEmailTraffic()) {
      console.log('[REFERRAL CLASSIFICATION] ✅ Email traffic detected (referrer stripped by email client)');
      return 'email';
    }

    for (var i = 0; i < aiAssistantSources.length; i++) {
      if (referrer.includes(aiAssistantSources[i])) {
        console.log('[REFERRAL CLASSIFICATION] ✅ Detected AI Assistant source:', aiAssistantSources[i]);
        return 'ai_assistant';
      }
    }

    if (userAgent.includes('ccbot') || userAgent.includes('chatgptbot')) {
      console.log('[REFERRAL CLASSIFICATION] ✅ Detected AI bot in user agent:', userAgent);
      return 'ai_assistant';
    }

    console.log('[REFERRAL CLASSIFICATION] Standard traffic - referrer:', referrer || '(direct/organic)');
    return null;
  }

  // Delay page_view until Termly consent is resolved (prevents race condition)
  function firePageView() {
    console.log('[GA4 RACE CONDITION] firePageView() called at', new Date().toISOString());

    if (typeof window.ga4Diagnostics !== 'undefined') {
      window.ga4Diagnostics.pageViewFired = true;
      window.ga4Diagnostics.log('Page view about to fire');
    }

    var referrerData = {
      'page_path': window.location.pathname,
      'page_title': document.title,
      'referrer': document.referrer,
      'timestamp': new Date().toISOString(),
      'userAgent': navigator.userAgent
    };

    // Add AI assistant or email channel if detected
    var trafficChannel = classifyTrafficSource();
    if (trafficChannel === 'email') {
      referrerData['traffic_source'] = 'email';
      referrerData['traffic_medium'] = 'email';
      console.log('[GA4 REFERRAL FIX] ✅ EMAIL traffic properly tagged (referrer stripped by email client)');
      console.log('[GA4 EMAIL FIX] User Agent:', navigator.userAgent);
      console.log('[GA4 EMAIL FIX] WARNING: Ensure email links include utm_source=email&utm_medium=email for better tracking');
      if (window.ga4Diagnostics) window.ga4Diagnostics.logEvent('page_view', 'email traffic');
    } else if (trafficChannel === 'ai_assistant') {
      referrerData['traffic_source'] = trafficChannel;
      console.log('[GA4 REFERRAL FIX] ✅ AI Assistant traffic properly tagged:', trafficChannel);
      if (window.ga4Diagnostics) window.ga4Diagnostics.logEvent('page_view', 'ai_assistant traffic');
    } else {
      console.log('[GA4 REFERRAL FIX] Standard traffic - referrer will be preserved:', document.referrer || '(direct)');
      if (window.ga4Diagnostics) window.ga4Diagnostics.logEvent('page_view', 'referrer: ' + (document.referrer || 'none'));
      // Log raw referrer for debugging
      if (!document.referrer) {
        console.log('[GA4 REFERRAL FIX] ⚠️ No referrer found - could be email, direct, or https->http');
        if (window.ga4Diagnostics) window.ga4Diagnostics.log('⚠️ ISSUE: No referrer - this will show as Direct in GA4');
      }
    }

    console.log('[GA4] Page View Event Data:', referrerData);
    console.log('[GA4 RACE CONDITION] Sending page_view with consent state AFTER Termly resolved');

    gtag('event', 'page_view', referrerData);
    console.log('[GA4 RACE CONDITION] ✅ Page view fired - referral attribution should now be correct');
  }

  // Wait for Termly to update consent before firing page_view
  // If Termly hasn't fired within 1.5s, fire anyway (user may have disabled cookies)
  console.log('[GA4 RACE CONDITION] Starting 1.5s timeout for Termly consent update...');
  var pageViewTimeout = setTimeout(function() {
    console.log('[GA4 RACE CONDITION] ⚠️ Timeout (1.5s) - Termly did not update consent in time');
    console.log('[GA4 RACE CONDITION] Firing page_view with default/initial consent state');
    firePageView();
  }, 1500);

  // Listen for Termly consent resolution
  window.addEventListener('consentStatusChange', function(e) {
    clearTimeout(pageViewTimeout);
    console.log('[GA4 RACE CONDITION] ✅ Termly consent received before timeout');
    console.log('[GA4 RACE CONDITION] Firing page_view with USER-ACCEPTED consent state');
    firePageView();
  });

  // Fallback: if Termly never fires, fire on DOMContentLoaded
  var pageViewFired = false;
  document.addEventListener('DOMContentLoaded', function() {
    console.log('[GA4 RACE CONDITION] DOMContentLoaded fired');
    if (pageViewTimeout) {
      // Page view not yet fired, so fire it now
      clearTimeout(pageViewTimeout);
      console.log('[GA4 RACE CONDITION] ℹ️ Page view not yet sent, DOMContentLoaded fallback triggering');
      firePageView();
      pageViewFired = true;
    } else {
      console.log('[GA4 RACE CONDITION] ✅ Page view already fired before DOMContentLoaded');
      pageViewFired = true;
    }
  });

  // Wrapper to ensure consent events are queued properly
  function fireConversionEvent(eventName, eventData) {
    console.log('[GA4 EVENT QUEUE] Processing ' + eventName + ' event');
    // If page_view already fired, send immediately; otherwise queue it
    if (pageViewFired) {
      console.log('[GA4 EVENT QUEUE] ✅ Page view already sent - sending ' + eventName + ' immediately');
      console.log('[GA4] ' + eventName + ' Event (after page view):', eventData);
      gtag('event', eventName, eventData);
      console.log('[GA4 EVENT QUEUE] ✅ ' + eventName + ' event sent');
    } else {
      // Queue event to fire after page_view
      console.log('[GA4 EVENT QUEUE] ⏳ Page view not yet sent - queueing ' + eventName + ' until consent resolved');
      window.addEventListener('consentStatusChange', function queuedEventListener() {
        console.log('[GA4 EVENT QUEUE] ✅ Consent resolved - sending queued ' + eventName + ' event');
        console.log('[GA4] ' + eventName + ' Event (queued after consent):', eventData);
        gtag('event', eventName, eventData);
        console.log('[GA4 EVENT QUEUE] ✅ Queued ' + eventName + ' event sent');
        window.removeEventListener('consentStatusChange', queuedEventListener);
      });
    }
  }

  @if (Model.ViewItemModel != null)
  {
    <text>
      fireConversionEvent("view_item", {
        currency: "USD",
        value: @Model.ViewItemModel.Price,
        items: [
          {
            item_id: "@Model.ViewItemModel.Sku",
            item_name: "@Model.ViewItemModel.Name",
            index: 0,
            item_brand: "@Model.ViewItemModel.Brand",
            item_category: "@Model.ViewItemModel.Category",
            price: @Model.ViewItemModel.Price
          }
        ]
      });
    </text>
  }

  @if (Model.BeginCheckoutModel != null)
  {
    <text>
      var beginCheckoutEvent = {
        currency: "USD",
        value: @Model.BeginCheckoutModel.Value,
        items: [
          @for (var i = 0; i < Model.BeginCheckoutModel.Items.Count(); i++)
          {
            var item = Model.BeginCheckoutModel.Items[i];
            <text>
              {
                item_id: "@item.Sku",
                item_name: "@item.Name",
                index: @i,
                item_brand: "@item.Brand",
                item_category: "@item.Category",
                price: @item.Price,
                quantity: @item.Quantity
              },
            </text>
          }
        ]
      };
      console.log('[GA4] Begin Checkout Event:', beginCheckoutEvent);
      fireConversionEvent("begin_checkout", beginCheckoutEvent);
    </text>
  }

  @if (Model.ViewCartModel != null)
  {
    <text>
      fireConversionEvent("view_cart", {
        currency: "USD",
        value: @Model.ViewCartModel.Value,
        items: [
          @for (var i = 0; i < Model.ViewCartModel.Items.Count(); i++)
          {
            var item = Model.ViewCartModel.Items[i];
            <text>
              {
                item_id: "@item.Sku",
                item_name: "@item.Name",
                index: @i,
                item_brand: "@item.Brand",
                item_category: "@item.Category",
                price: @item.Price,
                quantity: @item.Quantity
              },
            </text>
          }
        ]
      });
    </text>
  }

  @if (Model.PurchaseModel != null)
  {
    <text>
      var purchaseEvent = {
        transaction_id: @Model.PurchaseModel.OrderId,
        value: @Model.PurchaseModel.Value,
        tax: @Model.PurchaseModel.Tax,
        shipping: @Model.PurchaseModel.Shipping,
        currency: "USD",
        items: [
          @for (var i = 0; i < Model.PurchaseModel.OrderItems.Count(); i++)
          {
            var item = Model.PurchaseModel.OrderItems[i];
            <text>
              {
                item_id: "@item.Sku",
                item_name: "@item.Name",
                index: @i,
                item_brand: "@item.Brand",
                item_category: "@item.Category",
                price: @item.Price,
                quantity: @item.Quantity
              },
            </text>
          }
        ]
      };
      console.log('[GA4] Purchase Event:', purchaseEvent);
      fireConversionEvent("purchase", purchaseEvent);
    </text>
  }
</script>