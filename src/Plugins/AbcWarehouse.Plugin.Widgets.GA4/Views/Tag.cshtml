@model AbcWarehouse.Plugin.Widgets.GA4.Models.GA4Model

@{
  var debugModeText = Model.IsDebugMode ? ", { 'debug_mode':true }" : string.Empty;
}

<!-- Google tag (gtag.js) with Consent Mode v2 & AI Assistant Channel Grouping -->
<script src="https://www.googletagmanager.com/gtag/js?id=@Model.GoogleTag"></script>
<script>
  console.log('[GA4] Tag initialization starting');
  console.log('[GA4] Script load time:', new Date().toISOString());

  // Check if bots/internal traffic was already filtered by _Root.Head.cshtml
  // If ga4Diagnostics exists, consent mode was already initialized by _Root.Head.cshtml
  if (typeof window.ga4Diagnostics === 'undefined') {
    console.warn('[GA4] ga4Diagnostics not initialized - _Root.Head.cshtml may not have loaded');
    return; // Exit - _Root.Head.cshtml must load first for consent mode
  }

  // Ensure gtag is available (defined by _Root.Head.cshtml)
  if (typeof gtag === 'undefined') {
    console.warn('[GA4] gtag() function not available - _Root.Head.cshtml must load first');
    return; // Exit - _Root.Head.cshtml must load first
  }

  // Verify referrer policy allows sending referrer (critical for attribution)
  var referrerPolicyMeta = document.querySelector('meta[name="referrer"]');
  var referrerPolicy = referrerPolicyMeta ? referrerPolicyMeta.getAttribute('content') : 'not set';
  console.log('[GA4 REFERRER POLICY] Current policy:', referrerPolicy, '(controls HTTP Referrer header sent to GA4)');
  if (referrerPolicy === 'no-referrer' || referrerPolicy === 'origin') {
    console.warn('[GA4 REFERRER POLICY] ⚠️ CRITICAL: Referrer policy blocks HTTP Referrer header! GA4 cannot attribute traffic → will show as "unassigned". Use "strict-origin-when-cross-origin" or "unsafe-url"');
  } else if (referrerPolicy === 'strict-origin-when-cross-origin' || referrerPolicy === 'unsafe-url') {
    console.log('[GA4 REFERRER POLICY] ✅ Referrer policy allows GA4 attribution for cross-origin traffic');
  }

  // Consent mode was already initialized by _Root.Head.cshtml
  // Just verify the current state
  var termlyReady = typeof window.consentStatus !== 'undefined';
  console.log('[GA4 CONSENT] Termly pre-loaded:', termlyReady);

  if (termlyReady) {
    console.log('[GA4 CONSENT] Termly consent active - analytics_storage:', window.consentStatus.analytics_storage);
  } else {
    console.log('[GA4 CONSENT] Termly not yet loaded - using _Root.Head.cshtml defaults');
  }

  // Warn if Termly is denying analytics storage
  if (typeof window.consentStatus !== 'undefined' && window.consentStatus.analytics_storage === false) {
    console.warn('[GA4 CONSENT] ⚠️ WARNING: analytics_storage is DENIED by Termly - GA4 will NOT track referral data. User must accept analytics in cookie banner.');
  }

  gtag('js', new Date());

  console.log('[GA4] Initializing with tag: @Model.GoogleTag');
  console.log('[GA4] Referrer:', document.referrer || '(direct)');
  console.log('[GA4] User Agent:', navigator.userAgent);

  // Detect email traffic by checking user agent (email clients strip referrer)
  function detectEmailTraffic() {
    var userAgent = navigator.userAgent.toLowerCase();
    var emailClientIndicators = [
      'apple mail',
      'outlook',
      'thunderbird',
      'gmail',
      'yahoo mail',
      'aol',
      'mail app',
      'ios mail',
      'android mail',
      'mobile safari.*mail',
      'mailspring',
      'the bat',
      'evolution',
      'mutt'
    ];

    console.log('[EMAIL DETECTION] Checking user agent for email client indicators');
    for (var i = 0; i < emailClientIndicators.length; i++) {
      if (userAgent.includes(emailClientIndicators[i])) {
        console.log('[EMAIL DETECTION] ✅ Email client detected:', emailClientIndicators[i]);
        return true;
      }
    }

    // Check for common email app contexts
    if (window.location.href.includes('utm_medium=email') ||
        window.location.href.includes('utm_source=email')) {
      console.log('[EMAIL DETECTION] ✅ Email UTM parameter detected in URL');
      return true;
    }

    console.log('[EMAIL DETECTION] No email client detected (standard browser)');
    return false;
  }

  // Detect traffic source early to set session-level source/medium (required for GA4 referral attribution post-May 2024)
  function getSessionSource() {
    var referrer = document.referrer.toLowerCase();
    var userAgent = navigator.userAgent.toLowerCase();
    var searchUrl = window.location.href.toLowerCase();
    var urlParams = new URLSearchParams(window.location.search);

    // Step 1: Check for click ID parameters (Google Ads, Facebook, Microsoft) — highest priority
    var gclid = urlParams.get('gclid');
    var fbclid = urlParams.get('fbclid');
    var msclkid = urlParams.get('msclkid');
    var ttclid = urlParams.get('ttclid');

    if (gclid) {
      console.log('[GA4 SESSION SOURCE] Google Ads detected (gclid)');
      return { source: 'google', medium: 'cpc' };
    }
    if (fbclid) {
      console.log('[GA4 SESSION SOURCE] Facebook Ads detected (fbclid)');
      return { source: 'facebook', medium: 'cpc' };
    }
    if (msclkid) {
      console.log('[GA4 SESSION SOURCE] Microsoft Ads detected (msclkid)');
      return { source: 'bing', medium: 'cpc' };
    }
    if (ttclid) {
      console.log('[GA4 SESSION SOURCE] TikTok Ads detected (ttclid)');
      return { source: 'tiktok', medium: 'cpc' };
    }

    // Step 2: Check URL for UTM params (second priority)
    var utmSource = urlParams.get('utm_source');
    var utmMedium = urlParams.get('utm_medium');
    var utmCampaign = urlParams.get('utm_campaign');
    var utmContent = urlParams.get('utm_content');
    var utmTerm = urlParams.get('utm_term');

    if (utmSource || utmMedium) {
      console.log('[GA4 SESSION SOURCE] UTM params found - source:', utmSource, 'medium:', utmMedium);
      if (utmCampaign) console.log('[GA4 SESSION SOURCE] Campaign:', utmCampaign);
      return {
        source: utmSource || 'direct',
        medium: utmMedium || 'organic',
        campaign: utmCampaign,
        content: utmContent,
        term: utmTerm
      };
    }

    // Step 3: Detect organic search engines (Google, Bing, DuckDuckGo, Yahoo, Baidu, Yandex)
    var searchEngines = [
      { domain: 'google.', source: 'google' },
      { domain: 'bing.com', source: 'bing' },
      { domain: 'duckduckgo.com', source: 'duckduckgo' },
      { domain: 'search.yahoo.com', source: 'yahoo' },
      { domain: 'baidu.com', source: 'baidu' },
      { domain: 'yandex.', source: 'yandex' }
    ];

    for (var i = 0; i < searchEngines.length; i++) {
      if (referrer.includes(searchEngines[i].domain)) {
        console.log('[GA4 SESSION SOURCE] Organic search detected:', searchEngines[i].source);
        return { source: searchEngines[i].source, medium: 'organic' };
      }
    }

    // Step 4: Detect social media platforms
    var socialPlatforms = [
      { domain: 'facebook.com', source: 'facebook', medium: 'social' },
      { domain: 'instagram.com', source: 'instagram', medium: 'social' },
      { domain: 'twitter.com', source: 'twitter', medium: 'social' },
      { domain: 'x.com', source: 'x', medium: 'social' },
      { domain: 'linkedin.com', source: 'linkedin', medium: 'social' },
      { domain: 'pinterest.com', source: 'pinterest', medium: 'social' },
      { domain: 'reddit.com', source: 'reddit', medium: 'social' },
      { domain: 'tiktok.com', source: 'tiktok', medium: 'social' },
      { domain: 'youtube.com', source: 'youtube', medium: 'social' },
      { domain: 'youtube.co', source: 'youtube', medium: 'social' },
      { domain: 'threads.net', source: 'threads', medium: 'social' },
      { domain: 'mastodon.', source: 'mastodon', medium: 'social' }
    ];

    for (var i = 0; i < socialPlatforms.length; i++) {
      if (referrer.includes(socialPlatforms[i].domain)) {
        console.log('[GA4 SESSION SOURCE] Social media detected:', socialPlatforms[i].source);
        return { source: socialPlatforms[i].source, medium: socialPlatforms[i].medium };
      }
    }

    // Step 5: Detect email traffic (referrer stripped by client)
    if (!referrer && detectEmailTraffic()) {
      console.log('[GA4 SESSION SOURCE] Email traffic detected (referrer stripped)');
      return { source: 'email', medium: 'email' };
    }

    // Step 6: Detect AI Assistant traffic
    var aiSources = ['openai.com', 'chatgpt.com', 'chat.openai.com', 'gemini.google.com', 'bard.google.com', 'claude.ai', 'copilot.microsoft.com', 'perplexity.ai'];
    for (var i = 0; i < aiSources.length; i++) {
      if (referrer.includes(aiSources[i])) {
        console.log('[GA4 SESSION SOURCE] AI Assistant detected');
        return { source: 'ai_assistant', medium: 'referral' };
      }
    }
    if (userAgent.includes('ccbot') || userAgent.includes('chatgptbot')) {
      console.log('[GA4 SESSION SOURCE] AI bot detected in user agent');
      return { source: 'ai_assistant', medium: 'referral' };
    }

    // Step 7: Detect newsletter/marketing platforms (ConvertKit, Substack, Mailchimp, ActiveCampaign, etc.)
    var marketingPlatforms = [
      { domain: 'convertkit.com', source: 'convertkit', medium: 'email' },
      { domain: 'substack.com', source: 'substack', medium: 'email' },
      { domain: 'mailchimp.com', source: 'mailchimp', medium: 'email' },
      { domain: 'activecampaign.com', source: 'activecampaign', medium: 'email' },
      { domain: 'klaviyo.com', source: 'klaviyo', medium: 'email' },
      { domain: 'drip.com', source: 'drip', medium: 'email' },
      { domain: 'getresponse.com', source: 'getresponse', medium: 'email' }
    ];

    for (var i = 0; i < marketingPlatforms.length; i++) {
      if (referrer.includes(marketingPlatforms[i].domain)) {
        console.log('[GA4 SESSION SOURCE] Marketing platform detected:', marketingPlatforms[i].source);
        return { source: marketingPlatforms[i].source, medium: marketingPlatforms[i].medium };
      }
    }

    // Step 8: Handle standard referrer (extract domain and classify)
    if (referrer) {
      try {
        var referrerUrl = new URL(document.referrer);
        var referrerDomain = referrerUrl.hostname.replace('www.', '');
        var isInternal = referrerDomain === window.location.hostname.replace('www.', '');

        if (isInternal) {
          console.log('[GA4 SESSION SOURCE] Internal referrer detected - treating as direct');
          return { source: '(direct)', medium: '(direct)' };
        } else {
          console.log('[GA4 SESSION SOURCE] External referrer:', referrerDomain);
          return { source: referrerDomain, medium: 'referral' };
        }
      } catch(e) {
        console.log('[GA4 SESSION SOURCE] Could not parse referrer URL:', e.message);
        return { source: 'direct', medium: 'direct' };
      }
    }

    // Step 9: No referrer, no UTM params, no email = direct traffic (user typed URL or bookmarked)
    console.log('[GA4 SESSION SOURCE] No referrer/UTM/email detected - classified as direct');
    return { source: 'direct', medium: 'direct' };
  }

  // Enable event queueing to buffer events during consent race condition
  // Note: GA4 automatically detects source/medium from HTTP Referrer header and UTM parameters
  // This is not something we can override - GA4 handles it internally on first pageview
  var sessionSource = getSessionSource();

  // Set cookie flags based on protocol (secure flag requires HTTPS)
  var isHttps = window.location.protocol === 'https:';
  var cookieFlags = isHttps ? 'SameSite=Lax;secure' : 'SameSite=Lax';
  console.log('[GA4 COOKIES] Protocol:', window.location.protocol, '| Cookie flags:', cookieFlags);

  var ga4Config = {
    'allow_google_signals': false,
    'allow_ad_personalization_signals': false,
    'cookie_flags': cookieFlags,
    'cookie_domain': 'auto'
  };

  @if (!string.IsNullOrEmpty(debugModeText))
  {
    <text>
    ga4Config['debug_mode'] = true;
    </text>
  }
  console.log('[GA4 CONFIG] GA4 will determine session source/medium from HTTP Referrer and UTM params');
  console.log('[GA4 CONFIG] Detected (for logging): ' + sessionSource.source + '/' + sessionSource.medium);
  gtag('config','@Model.GoogleTag', ga4Config);

  // Delay page_view until Termly consent is resolved (prevents race condition)
  var pageViewFired = false;
  var pageViewTimeout = null;

  function isAnalyticsGranted() {
    // Check if analytics consent is granted
    if (typeof window.consentStatus !== 'undefined') {
      return window.consentStatus.analytics_storage !== false;
    }
    // If Termly hasn't updated yet, check our last known state
    return true; // Default to true if unknown (Termly will deny if needed)
  }

  function shouldFirePageView() {
    var analyticsGranted = isAnalyticsGranted();
    console.log('[GA4 RACE CONDITION] Analytics consent check: ' + (analyticsGranted ? 'GRANTED' : 'DENIED'));
    return analyticsGranted;
  }

  function firePageView() {
    console.log('[GA4 RACE CONDITION] firePageView() called at', new Date().toISOString());

    if (typeof window.ga4Diagnostics !== 'undefined') {
      window.ga4Diagnostics.pageViewFired = true;
      window.ga4Diagnostics.log('Page view about to fire');
    }

    var referrerData = {
      'page_path': window.location.pathname,
      'page_title': document.title
    };

    console.log('[GA4] Page View Event Data:', referrerData);
    console.log('[GA4] Referral attribution handled at session level: ', sessionSource.source + '/' + sessionSource.medium);
    console.log('[GA4 RACE CONDITION] Sending page_view with consent state AFTER Termly resolved');

    gtag('event', 'page_view', referrerData);
    console.log('[GA4 RACE CONDITION] ✅ Page view fired - referral attribution should now be correct');
  }

  // Wait up to 3s for Termly to load and determine user consent
  console.log('[GA4 RACE CONDITION] Starting 3s timeout for Termly consent...');
  pageViewTimeout = setTimeout(function() {
    console.log('[GA4 RACE CONDITION] ⚠️ Timeout (3s) - Termly did not respond');
    if (shouldFirePageView() && !pageViewFired) {
      console.log('[GA4 RACE CONDITION] Firing page_view with timeout fallback');
      firePageView();
      pageViewFired = true;
    } else {
      console.log('[GA4 RACE CONDITION] Analytics denied - NOT firing page_view');
    }
  }, 3000);

  // Listen for Termly consent update (fires before user sees banner if already made choice)
  // Note: _Root.Head.cshtml also listens to this event, but for different purposes (updating gtag consent)
  // This listener only fires page_view when analytics is granted
  var termlyConsentListener = function(e) {
    console.log('[GA4] consentStatusChange event detected');
    clearTimeout(pageViewTimeout);
    if (shouldFirePageView() && !pageViewFired) {
      console.log('[GA4 RACE CONDITION] ✅ Termly consent update received - analytics GRANTED');
      console.log('[GA4 RACE CONDITION] Firing page_view with user consent');
      firePageView();
      pageViewFired = true;
    } else if (!pageViewFired) {
      console.log('[GA4 RACE CONDITION] ✅ Termly consent update received - analytics DENIED');
      console.log('[GA4 RACE CONDITION] NOT firing page_view - user denied analytics');
    }
  };

  // Add listener only if it hasn't been added already (safety check)
  if (!window.ga4PageViewListener) {
    window.addEventListener('consentStatusChange', termlyConsentListener);
    window.ga4PageViewListener = true;
  }

  // Fallback: fire on DOMContentLoaded if still not fired
  document.addEventListener('DOMContentLoaded', function() {
    console.log('[GA4 RACE CONDITION] DOMContentLoaded event fired');
    if (!pageViewFired) {
      clearTimeout(pageViewTimeout);
      if (shouldFirePageView()) {
        console.log('[GA4 RACE CONDITION] DOMContentLoaded: firing page_view');
        firePageView();
        pageViewFired = true;
      } else {
        console.log('[GA4 RACE CONDITION] DOMContentLoaded: analytics denied - NOT firing');
      }
    }
  });

  // Wrapper to ensure consent events are queued properly
  function fireConversionEvent(eventName, eventData) {
    console.log('[GA4 EVENT QUEUE] Processing ' + eventName + ' event');
    // If page_view already fired, send immediately; otherwise queue it
    if (pageViewFired) {
      console.log('[GA4 EVENT QUEUE] ✅ Page view already sent - sending ' + eventName + ' immediately');
      console.log('[GA4] ' + eventName + ' Event (after page view):', eventData);
      gtag('event', eventName, eventData);
      console.log('[GA4 EVENT QUEUE] ✅ ' + eventName + ' event sent');
    } else {
      // Queue event to fire after page_view
      console.log('[GA4 EVENT QUEUE] ⏳ Page view not yet sent - queueing ' + eventName + ' until consent resolved');
      window.addEventListener('consentStatusChange', function queuedEventListener() {
        console.log('[GA4 EVENT QUEUE] ✅ Consent resolved - sending queued ' + eventName + ' event');
        console.log('[GA4] ' + eventName + ' Event (queued after consent):', eventData);
        gtag('event', eventName, eventData);
        console.log('[GA4 EVENT QUEUE] ✅ Queued ' + eventName + ' event sent');
        window.removeEventListener('consentStatusChange', queuedEventListener);
      });
    }
  }

  @if (Model.ViewItemModel != null)
  {
    <text>
      fireConversionEvent("view_item", {
        currency: "USD",
        value: @Model.ViewItemModel.Price,
        items: [
          {
            item_id: "@Model.ViewItemModel.Sku",
            item_name: "@Model.ViewItemModel.Name",
            index: 0,
            item_brand: "@Model.ViewItemModel.Brand",
            item_category: "@Model.ViewItemModel.Category",
            price: @Model.ViewItemModel.Price
          }
        ]
      });
    </text>
  }

  @if (Model.BeginCheckoutModel != null)
  {
    <text>
      var beginCheckoutEvent = {
        currency: "USD",
        value: @Model.BeginCheckoutModel.Value,
        items: [
          @for (var i = 0; i < Model.BeginCheckoutModel.Items.Count(); i++)
          {
            var item = Model.BeginCheckoutModel.Items[i];
            <text>
              {
                item_id: "@item.Sku",
                item_name: "@item.Name",
                index: @i,
                item_brand: "@item.Brand",
                item_category: "@item.Category",
                price: @item.Price,
                quantity: @item.Quantity
              },
            </text>
          }
        ]
      };
      console.log('[GA4] Begin Checkout Event:', beginCheckoutEvent);
      fireConversionEvent("begin_checkout", beginCheckoutEvent);
    </text>
  }

  @if (Model.ViewCartModel != null)
  {
    <text>
      fireConversionEvent("view_cart", {
        currency: "USD",
        value: @Model.ViewCartModel.Value,
        items: [
          @for (var i = 0; i < Model.ViewCartModel.Items.Count(); i++)
          {
            var item = Model.ViewCartModel.Items[i];
            <text>
              {
                item_id: "@item.Sku",
                item_name: "@item.Name",
                index: @i,
                item_brand: "@item.Brand",
                item_category: "@item.Category",
                price: @item.Price,
                quantity: @item.Quantity
              },
            </text>
          }
        ]
      });
    </text>
  }

  @if (Model.PurchaseModel != null)
  {
    <text>
      var purchaseEvent = {
        transaction_id: @Model.PurchaseModel.OrderId,
        value: @Model.PurchaseModel.Value,
        tax: @Model.PurchaseModel.Tax,
        shipping: @Model.PurchaseModel.Shipping,
        currency: "USD",
        items: [
          @for (var i = 0; i < Model.PurchaseModel.OrderItems.Count(); i++)
          {
            var item = Model.PurchaseModel.OrderItems[i];
            <text>
              {
                item_id: "@item.Sku",
                item_name: "@item.Name",
                index: @i,
                item_brand: "@item.Brand",
                item_category: "@item.Category",
                price: @item.Price,
                quantity: @item.Quantity
              },
            </text>
          }
        ]
      };
      console.log('[GA4] Purchase Event:', purchaseEvent);
      fireConversionEvent("purchase", purchaseEvent);
    </text>
  }
</script>