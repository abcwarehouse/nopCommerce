@model AbcWarehouse.Plugin.Misc.DealTherapy.Models.DealTherapyResultModel
@inject INopHtmlHelper NopHtml
@{
    Layout = "_ColumnsOne";
    NopHtml.AddTitleParts("Your Deal Therapy Results");
}

<div class="page deal-therapy-result-page">
    <div class="page-title">
        <h1>Your Deal Therapy Results</h1>
    </div>
    <div class="page-body">
        <div class="deal-therapy-recommendation">
            <p>@Model.Recommendation</p>
        </div>

        <div class="deal-therapy-answer-summary">
            <h3>Your answers</h3>
            <ul>
                @foreach (var answer in Model.Answers)
                {
                    <li><strong>@answer.Key:</strong> @answer.Value</li>
                }
            </ul>
        </div>

        <div class="deal-therapy-cta">
            <a href="/" class="button-1">Shop Now</a>
            <a href="/deal-therapy" class="button-2">Retake Quiz</a>
        </div>
    </div>
</div>

<style>
    .deal-therapy-recommendation { background: #f5f5f5; border-left: 4px solid #e63328; padding: 16px 20px; margin-bottom: 28px; font-size: 1.1em; }
    .deal-therapy-answer-summary h3 { margin-bottom: 10px; }
    .deal-therapy-answer-summary ul { list-style: none; padding: 0; margin-bottom: 28px; }
    .deal-therapy-answer-summary li { padding: 4px 0; }
    .deal-therapy-cta { display: flex; gap: 12px; flex-wrap: wrap; }
</style>
