@using Nop.Plugin.Misc.AbcCore.Models;

@model ABCProductDetailsModel

<nop-card id="AbcProductDetails" asp-name="abc-product-details" asp-icon="fas fa-info" asp-title="ABC Product Details" asp-hide-block-attribute-name="AbcProductDetails" asp-hide="false">
    <div class="card-body">
        <div class="card card-default">
            <div class="card-body">
                @if (Model.ProductId > 0)
                {
                    <section class="content">

                        @* PLP Description *@
                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-label asp-for="@Model.PLPDescription" />
                            </div>
                            <div class="col-md-9">
                                <nop-editor asp-for="@Model.PLPDescription" />
                                <span asp-validation-for="@Model.PLPDescription"></span>
                            </div>
                        </div>

                        @* Mickey Shorr Landing Pages *@
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label><strong>Mickey Landing Pages</strong></label>
                            </div>
                            <div class="col-md-9">
                                <div id="mickey-lp-assignments">
                                    @if (!Model.CurrentLandingPages.Any())
                                    {
                                        <p class="text-muted" id="no-assignments-msg">Not on any landing page.</p>
                                    }
                                    else
                                    {
                                        <table class="table table-bordered table-sm" style="margin-bottom:10px;" id="lp-table">
                                            <thead>
                                                <tr>
                                                    <th>Landing Page</th>
                                                    <th>Date Range</th>
                                                    <th>Status</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody id="lp-table-body">
                                                @foreach (var lp in Model.CurrentLandingPages)
                                                {
                                                    <tr id="lp-row-@lp.MappingId">
                                                        <td>@lp.Name</td>
                                                        <td>@lp.DateRange</td>
                                                        <td>
                                                            @if (lp.IsActive)
                                                            {
                                                                <span class="label label-success">Active</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="label label-default">Inactive</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            <button type="button"
                                                                    class="btn btn-danger btn-xs mickey-lp-remove"
                                                                    data-mapping-id="@lp.MappingId">
                                                                Remove
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>

                                @if (Model.AvailableLandingPages.Any())
                                {
                                    <div class="input-group" style="max-width:450px;">
                                        <select id="mickey-lp-select" class="form-control">
                                            <option value="">— Select Landing Page —</option>
                                            @foreach (var item in Model.AvailableLandingPages)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        </select>
                                        <span class="input-group-btn">
                                            <button type="button" id="mickey-lp-add" class="btn btn-success">
                                                Add to Landing Page
                                            </button>
                                        </span>
                                    </div>
                                }
                                else if (!Model.CurrentLandingPages.Any())
                                {
                                    <p class="text-muted">No landing pages exist yet. <a href="/Admin/MickeyLandingPage/Create" target="_blank">Create one</a>.</p>
                                }
                                else
                                {
                                    <p class="text-muted">Product is on all available landing pages.</p>
                                }

                                <div id="mickey-lp-message" style="margin-top:6px;"></div>
                            </div>
                        </div>

                    </section>
                }
                else
                {
                    @T("SevenSpikes.NopQuickTabs.Admin.NopProductsTabTitle.SaveBeforeEdit")
                }
            </div>
        </div>
    </div>
    <script type="text/javascript">
        $(document).ready(function () {
            // Move card to top of product-cards container
            var element = document.getElementById('AbcProductDetails');
            var parent = document.getElementById('product-cards');
            parent.prepend(element);

            var productId = @Model.ProductId;

            // ── Add to landing page ────────────────────────────────────────
            $('#mickey-lp-add').click(function () {
                var landingPageId = parseInt($('#mickey-lp-select').val());
                if (!landingPageId) {
                    showMickeyMsg('Select a landing page first.', 'danger');
                    return;
                }
                $.post('/Admin/MickeyLandingPage/AddProduct',
                    { landingPageId: landingPageId, productId: productId },
                    function (data) {
                        if (data.success) {
                            showMickeyMsg('Added. Save the product to see updated status.', 'success');
                            // Reload the whole widget section for simplicity
                            location.reload();
                        } else {
                            showMickeyMsg(data.message, 'danger');
                        }
                    }
                );
            });

            // ── Remove from landing page ───────────────────────────────────
            $(document).on('click', '.mickey-lp-remove', function () {
                var mappingId = $(this).data('mapping-id');
                if (!confirm('Remove this product from the landing page?')) return;
                var row = $(this).closest('tr');
                $.post('/Admin/MickeyLandingPage/RemoveProduct',
                    { mappingId: mappingId },
                    function (data) {
                        if (data.success) {
                            row.remove();
                            if ($('#lp-table-body tr').length === 0) {
                                $('#lp-table').replaceWith('<p class="text-muted" id="no-assignments-msg">Not on any landing page.</p>');
                            }
                        } else {
                            showMickeyMsg(data.message, 'danger');
                        }
                    }
                );
            });

            function showMickeyMsg(msg, type) {
                $('#mickey-lp-message')
                    .html('<span class="alert alert-' + type + '" style="padding:4px 8px;">' + msg + '</span>');
            }
        });
    </script>
</nop-card>
