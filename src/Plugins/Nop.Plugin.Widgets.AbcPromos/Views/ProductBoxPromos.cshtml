@using Nop.Plugin.Misc.AbcCore.Domain;
@using System.Linq;
@model AbcPromo[]

@* ABC: custom *@
@inject INopHtmlHelper NopHtml

@{
    NopHtml.AddCssFileParts("~/Plugins/Widgets.AbcPromos/styles/product-box.css");
}

@for (int i = 0; i < 2; i++)
{
    var promo = Model[i];
    if (promo != null) {
        <a class="product-box-specials" href="@promo.GetPdfPath()" target="_blank" rel="noopener">@promo.Description</a>
    }
    else
    {
        <span class="product-box-specials">&nbsp;</span>
    }
}
