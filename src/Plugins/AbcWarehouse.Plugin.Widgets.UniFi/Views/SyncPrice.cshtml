@inject INopHtmlHelper NopHtml

@{
    NopHtml.AddCssFileParts("~/Plugins/Widgets.UniFi/styles/styles.css");
}

<div class="sync-price"></div>
<div class="affirm-con">
    <div class="instore-img">
        <img src="https://www.abcwarehouse.com/images/uploaded/financing/affirmlogo.jpg" class="affirm" alt="Affirm" />
        <img src="https://www.abcwarehouse.com/images/uploaded/applepay.png" alt="Apple" class="apple" />
        <img src="https://www.abcwarehouse.com/images/uploaded/klarna.png" alt="Klarna" class="klarna" />
    </div>
    <div class="in-store">
        Available in-store only.
    </div>
</div>

<style>
.affirm img {
    max-height: 15px;
    margin-right: 3px;
}
.affirm-con {
    margin-bottom: 15px;
}
.affirm {
    display: flex;
    align-items: center;
}
.affirm .instore-img {
    display: flex;
    align-items: center;
}
.affirm .in-store {
    margin-left: 8px;
}

</style>